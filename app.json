{
  "expo": {
    "name": "YouTubeX",
    "slug": "youtubex",
    "version": "1.0.0",
    "description": "My YouTube clone project",
    "owner": "rabiibenrioui",
    "orientation": "portrait",
    "icon": "./assets/app/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/icons/youtubeIcon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "bundleIdentifier": "com.rabiibenrioui.youtubex",
      "supportsTablet": true
    },
    "android": {
      "package": "com.rabiibenrioui.youtubex",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/icons/youtubeIcon.png",
        "backgroundImage": "./assets/icons/youtubeIcon.png",
        "monochromeImage": "./assets/icons/youtubeIcon.png"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/icons/youtubeIcon.png"
    }
  }
}
